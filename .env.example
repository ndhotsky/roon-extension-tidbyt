# Tidbyt credentials — required
# Find your Device ID in the Tidbyt app under Settings → Developer
TIDBYT_DEVICE_ID=your-tidbyt-device-id

# Generate an API token at https://tidbyt.com/pages/apps
TIDBYT_API_TOKEN=your-tidbyt-api-token

# Roon Zone ID (optional — can also be set via the Roon extension settings UI)
# Run with --verbose or check the console on startup to see available zone IDs
ROON_ZONE_ID=

# Advanced overrides (optional — defaults are sensible for most setups)
# ROON_DEBOUNCE_MS=1500
# ROON_MIN_PUSH_INTERVAL_SEC=3
